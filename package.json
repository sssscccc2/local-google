{
  "name": "tiandaochouqin-mahjong",
  "version": "1.0.0",
  "description": "天道酬勤麻将机",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "download-ext": "node scripts/download-extension.js",
    "download-singbox": "node scripts/download-singbox.js"
  },
  "dependencies": {
    "electron-store": "^10.0.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.fingerprint.browser",
    "productName": "天道酬勤麻将机",
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": null
    },
    "portable": {
      "artifactName": "天道酬勤麻将机.exe"
    },
    "files": [
      "src/**/*",
      "scripts/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "extensions",
        "to": "extensions",
        "filter": ["**/*"]
      },
      {
        "from": "src/extension-template",
        "to": "extension-template",
        "filter": ["**/*"]
      },
      {
        "from": "bin",
        "to": "bin",
        "filter": ["sing-box.exe"]
      }
    ],
    "directories": {
      "output": "dist"
    }
  }
}
